# ============================================================
# .gitignore — cft-anyons canonical repo
# ============================================================

# ---------- LaTeX build artifacts ----------
# Top-level build artifacts. Source .pdf files under references/pdfs/
# are tracked (they are reference material, not build output).
*.aux
*.log
*.out
*.toc
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.synctex.gz
*.synctex*
*.nav
*.snm
*.vrb
*.idx
*.ilg
*.ind
*.lof
*.lot
*.run.xml
*.bcf

# Top-level summary.pdf is built artifact; regenerate with `pdflatex summary.tex`.
# (PDFs under references/pdfs/ are source material — see negation below.)
/summary.pdf

# ---------- Lean ----------
.lake/
build/
_build/
.cache/

# ---------- Julia ----------
*.cov
*.jl.cov
*.jl.mem
deps/build.log
deps/deps.jl
deps/usr/

# ---------- Python (lit CLI, scripts) ----------
__pycache__/
*.pyc
*.pyo
.venv/
.python-version
*.egg-info/

# ---------- Literature DB (per-machine local cache) ----------
# papers.sqlite is gitignored per the source project's convention; the
# canonical content is schema.sql + seed_existing_pdfs.json + the
# markdown extractions under literature/md/. Each device runs
# `lit init` (and any subsequent enrichment) locally; the cross-device
# state is the committed schema/seed plus literature/md/ extractions.
literature/db/papers.sqlite
literature/db/papers.sqlite-*

# ---------- bd (beads) ----------
# JSONL is authoritative + tracked; SQLite is local cache.
.beads/beads.db
.beads/beads.db-journal
.beads/beads.db-wal
.beads/beads.db-shm
.beads/locks/
.beads/bd.sock
.beads/daemon.pid
.beads/embeddeddolt/

# ---------- Editor / OS ----------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ---------- Negations (track these despite patterns above) ----------
# Reference PDFs are source, not build output.
!references/pdfs/*.pdf
!references/**/*.pdf

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
